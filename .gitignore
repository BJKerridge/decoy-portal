# ==============================================================================
# 1. Monorepo / Global Rules
# ==============================================================================
node_modules/
.pnp
.pnp.js
dist/
build/
.cache/
*.log
logs/

# ==============================================================================
# 2. Infrastructure & Local State (Docker, Databases, Promtail)
# ==============================================================================
# Ignore persistent volume folders if mapped locally (e.g., pgdata)
.docker/
**/data/db/
**/data/pgdata/

# If Loki/Promtail write local positions or storage buffers
.positions.yaml
*positions.yaml

# ==============================================================================
# 3. Environment Variables & Secrets (CRITICAL)
# ==============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.*

# Ensure tracking of explicit example files
!.env.example

# ==============================================================================
# 4. DECOY-UI & DECOY-Orch (Next.js / TypeScript / Node)
# ==============================================================================
.next/
out/
next-env.d.ts

# npm/yarn/pnpm crash logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==============================================================================
# 5. DECOY-DataLayer (Java / Maven / Gradle)
# ==============================================================================
# Maven output
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.nextDevelopment
pom.xml.war
pom.xml.gpg
release.properties

# Gradle output
.gradle/
/build/

# Java specific runtime files
*.class
*.jar
*.war
*.ear
*.nar

# ==============================================================================
# 6. IDEs, Editors, & OS Files
# ==============================================================================
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS garbage
.DS_Store
.DS_Store?
ehthumbs.db
Thumbs.db